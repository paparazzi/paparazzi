      </location>
      <direction>
        <x>1</x>
        <y>0</y>
        <z>0</z>
      </direction>
    </force>

    <force name="MOTOR_BACK_couple1" frame="BODY" unit="LBS">
      <function>
        <product>
          <property>fcs/MOTOR_BACK_lag</property>
