        <product>
          <property>fcs/MOTOR_FRONT_lag</property>
          <value> 3.19 </value>
        </product>
      </function>
      <location unit="IN">
        <x>0</x>
        <y>19.68503935</y>
        <z>0</z>
      </location>
      <direction>
        <x>1</x>
        <y>0</y>
        <z>0</z>
      </direction>
    </force>

    <force name="MOTOR_FRONT_couple2" frame="BODY" unit="LBS">
      <function>
        <product>
          <property>fcs/MOTOR_FRONT_lag</property>
          <value> 3.19 </value>
        </product>
      </function>
      <location unit="IN">
        <x>0</x>
        <y>-19.68503935</y>
        <z>0</z>
      </location>
      <direction>
        <x>-1</x>
        <y>0</y>
        <z>0</z>
