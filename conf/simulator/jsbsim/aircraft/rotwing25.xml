    <property>fcs/YAW</property>
    <property>fcs/THRUST</property>
    <property>fcs/ROT_MECH</property>
    <property>fcs/de_lag</property>
    <property>fcs/airspeed2_ms</property>

    <!-- First the lift forces produced by each propeller -->

    <force name="MOTOR_FRONT" frame="BODY" unit="LBS">
      <function>
      <sum>
        <product>
          <property>fcs/MOTOR_FRONT_lag</property>
          <value> 26.06 </value>
        </product>
        <product>
          <property>fcs/MOTOR_RIGHT_lag</property>
          <property>fcs/sinskew</property>
          <value> 26.06 </value>
        </product>
      </sum>
      </function>
      <location unit="IN">
        <x>-21.89</x>
        <y>0</y>
        <z>0</z>
      </location>
      <direction>
        <x>0</x>
        <y>0</y>
        <z>-1</z>
      </direction>
    </force>

    <force name="MOTOR_RIGHT" frame="BODY" unit="LBS">
      <function>
        <product>
          <property>fcs/MOTOR_RIGHT_lag</property>
          <property>fcs/cosskew</property>
          <value> 26.06 </value>
        </product>
      </function>
      <location unit="IN">
        <x>0</x>
        <y>25.197</y>
        <z>0</z>
      </location>
      <direction>
        <x>0</x>
        <y>0</y>
        <z>-1</z>
      </direction>
    </force>

    <force name="MOTOR_BACK" frame="BODY" unit="LBS">
      <function>
        <sum>
          <product>
            <property>fcs/MOTOR_BACK_lag</property>
            <value> 26.06 </value>
          </product>
          <product>
              <property>fcs/MOTOR_LEFT_lag</property>
              <property>fcs/sinskew</property>
              <value> 26.06 </value>
          </product>
        </sum>
      </function>
      <location unit="IN">
        <x>21.89</x>
        <y>0</y>
        <z>0</z>
      </location>
      <direction>
        <x>0</x>
        <y>0</y>
        <z>-1</z>
      </direction>
    </force>

    <force name="MOTOR_LEFT" frame="BODY" unit="LBS">
      <function>
        <product>
          <property>fcs/MOTOR_LEFT_lag</property>
          <property>fcs/cosskew</property>
          <value> 26.06 </value>
        </product>
      </function>
      <location unit="IN">
        <x>0</x>
        <y>-25.197</y>
        <z>0</z>
      </location>
      <direction>
        <x>0</x>
        <y>0</y>
        <z>-1</z>
      </direction>
    </force>

    <force name="THRUST_X" frame="BODY" unit="LBS">
      <function>
        <product>
          <property>fcs/THRUST_X_lag</property>
          <value> 35.77 </value>
        </product>
      </function>
      <location unit="IN">
        <x>0</x>
        <y>0</y>
        <z>0</z>
      </location>
      <direction>
        <x>1</x>
        <y>0</y>
        <z>0</z>
      </direction>
    </force>

    <!-- Now the moment couples -->
    <force name="MOTOR_FRONT_couple1" frame="BODY" unit="LBS">
