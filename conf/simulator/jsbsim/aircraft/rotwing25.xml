  </external_reactions>

  <propulsion/>

  <flight_control name="FGFCS"/>

  <aerodynamics>
    <axis name="DRAG">
      <function name="aero/coefficient/CD">
        <description>Drag</description>
        <product>
          <property>aero/qbar-psf</property>
          <value>47.9</value> <!-- Conversion to pascals -->
          <value>0.0151</value> <!-- CD x Area (m^2) -->
          <value>0.224808943</value> <!-- N to LBS -->
          <value>20.0</value> <!-- some scaling factor -->
        </product>
      </function>
    </axis>

  <axis name="LIFT">
    <function name="aero/force/Lift_alpha"> 
      <product>
        <product> 
          <property>metrics/Sw-sqft</property> 
          <value> 0.0929 </value> <!-- FT^2 to M^2 -->
          <sum>
            <product>
              <value> 5.48 </value> <!-- CL_a -->
              <property>aero/alpha-rad</property> 
            </product>
            <value> 0.3 </value> <!-- CL_0 -->
          </sum>
        </product>  
      <property>aero/qbar-psf</property>
      <value>47.9</value> <!-- Conversion to pascals -->
      <property>fcs/sin2skew</property>
      <value> 0.2248</value> <!-- N to LBS -->  
      </product>
    </function>
   </axis>

    <axis name="SIDE">
    <function name="aero/force/Side_beta">
       <description>Side force due to beta</description>
       <product>
           <property>aero/qbar-psf</property>
           <property>metrics/Sw-sqft</property>
           <property>aero/beta-rad</property>
           <value>-0</value>
       </product>
    </function>
  </axis>

  <axis name="YAW">
    <function name="directional stability" frame="BODY" unit="FT*LBS">
       <product>
           <property>aero/qbar-psf</property>
           <property>metrics/Sv-sqft</property>
           <property>aero/beta-rad</property>
           <value>10.0</value>
       </product>
    </function>
  </axis>

  <axis name="ROLL">
    <function name="ailerons" frame="BODY" unit="FT*LBS">
       <product>
           <property>aero/qbar-psf</property>
           <property>fcs/AILERONS</property>
           <value>15.0</value>
       </product>
    </function>
  </axis>
  </aerodynamics>

</fdm_config>